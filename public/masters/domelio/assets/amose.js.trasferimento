  };

  // Helper: true if bundle has no market restriction or current market is in selected_markets (so we can prefer market-matching bundle when multiple bundles target same product)
  const bundleMatchesCurrentMarket = (field) => {
    const selectedMarkets = field?.selected_markets;
    if (!Array.isArray(selectedMarkets) || selectedMarkets.length === 0) return true;
    if (selectedMarkets.includes('all')) return true;
    const currentMarketId = currentMarketInfo?.id;
    const normalizedCurrent = normalizeMarketIdForComparison(currentMarketId);
    if (!normalizedCurrent) return true;
    return selectedMarkets.some(selectedMarket => {
      if (!selectedMarket) return false;
      if (selectedMarket === currentMarketId || selectedMarket === normalizedCurrent) return true;
      const normalizedSelected = normalizeMarketIdForComparison(selectedMarket);
      return normalizedSelected === normalizedCurrent || normalizedSelected === currentMarketId ||
        normalizedSelected.toLowerCase() === normalizedCurrent.toLowerCase();
    });
  };

  // Helper function to check if bundle is active
  const isBundleActive = (field) => {
    return field?.enable_quantity_options === true;
  };

  // Helper function to find active bundles first, then fallback to inactive
  const findActiveMetafieldEntry = (predicate) => {
    // First, try to find an active bundle
    for (const entry of spMetafieldEntries) {
      const [, field] = entry;
      try {
        if (predicate(field) && isBundleActive(field)) {
