    const appBase = (bd.appUrl || 'https://amosebundle-production.up.railway.app').replace(/\/$/, '');
    const urls = [
      bd.bannerConfettiUrl || (appBase + '/confetti.png'),
      bd.bannerChristmasUrl || (appBase + '/christmas.png'),
      bd.bannerValentineUrl || (appBase + '/valentine6.png')
    ];
    urls.forEach(function(u) { if (u) { var img = new Image(); img.src = u; } });
  })();

  const parseTranslationEntry = (entry) => {
    if (entry?.value === null && entry?.key === undefined && typeof entry === 'string') {
      try {
        return JSON.parse(entry);
      } catch {
        return null;
      }
    }
    if (!entry) return null;
    if (entry.marketId && entry.values) {
      return entry;
    }
    const rawValue = entry.value !== undefined ? entry.value : entry;
    if (!rawValue) return null;
    if (typeof rawValue === 'string') {
