        }
      } catch (error) {
        continue;
      }
    }
    return null;
  };

  // Helper to normalize market IDs for comparison (GraphQL format: gid://shopify/Market/123)
  const normalizeMarketIdForComparison = (marketId) => {
    if (!marketId) return '';
    const idStr = String(marketId).trim();
    if (!idStr) return '';
    if (idStr.toLowerCase().startsWith('gid://shopify/market/')) {
